# ──────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in your values
#  Never commit .env to version control
# ──────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Comma-separated Discord user IDs who have full bot-owner access
# These users can run owner-only commands (g!owner, g!wordlist, etc.)
OWNER_IDS=123456789012345678,987654321098765432

# ── Optional — Bot Identity ────────────────────────────────────

# Display name used in embeds and messages
BOT_NAME=GuardBot

# Default command prefix (can be overridden per-guild via g!setup prefix)
BOT_PREFIX=g!

# ── Optional — Logging ─────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Optional — Database ────────────────────────────────────────

# Path to the SQLite database file (relative to project root)
# Default: data/bot.db
DB_PATH=data/bot.db

# ── Optional — Wordlist (Global) ──────────────────────────────

# Maximum number of global wordlist URLs the bot owner can add
# Default: 20
WORDLIST_MAX_URLS=20

# How often to re-fetch all global wordlist URLs (in hours)
# Default: 6
WORDLIST_FETCH_INTERVAL_HOURS=6

# Maximum size of a single remote wordlist response (in bytes)
# Default: 512000 (500 KB)
WORDLIST_MAX_BYTES=512000

# HTTP request timeout for fetching remote wordlists (in seconds)
# Default: 10
WORDLIST_FETCH_TIMEOUT=10

# ── Optional — Network ─────────────────────────────────────────

# Shared secret used to authenticate requests between bot shards
# (Only needed if you run multi-process sharding)
# SHARD_SECRET=a-long-random-string

# ── Optional — Premium ─────────────────────────────────────────

# TTL in seconds for the in-memory premium guild cache
# Default: 60
PREMIUM_CACHE_TTL=60

# ── Optional — Verification Web Mode ─────────────────────────

# Base URL of your verification web server (for "web" verification mode)
# Leave blank if you only use captcha/none modes
# VERIFY_WEB_BASE_URL=https://verify.yourdomain.com